PORT=3001

# REQUIRED for production — sign/verify JWT sessions
JWT_SECRET=change-me-to-a-long-random-string

# STRONGLY RECOMMENDED — encrypts notification credentials (webhook URLs, API keys) at rest in SQLite.
# Must be a securely generated random value. Once set, do not change it or existing configs become unreadable.
# Generate with: openssl rand -hex 32
NOTIFICATIONS_ENCRYPTION_KEY=

# First-boot admin user seed (only used if no user with this username exists yet)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Session duration (default: 24 hours)
SESSION_DURATION_HOURS=24

# CORS — set to your frontend origin in production
CLIENT_ORIGIN=http://localhost:5173

# Base URL used in alert notification links
BASE_URL=http://localhost:5173

# How long to suppress repeat alerts for the same target (seconds, default: 3600)
ALERT_COOLDOWN_SECONDS=3600

# How often the NVD feed is refreshed (hours, default: 2)
NVD_SYNC_INTERVAL_HOURS=2

# How often the CISA KEV catalog is refreshed (hours, default: 24)
KEV_SYNC_INTERVAL_HOURS=24

# How often the CISA vulnrichment SSVC data is refreshed (hours, default: 24)
VULNRICHMENT_SYNC_INTERVAL_HOURS=24

# How often the CVE Program cvelistV5 repo is synced (hours, default: 24)
CVELIST_SYNC_INTERVAL_HOURS=24

# How many days to retain content diff files (default: 30)
DIFF_RETENTION_DAYS=30

# Directory for SQLite DB, snapshots, and diffs (relative to server working directory)
DATA_DIR=data

# Optional: path to a Chrome/Chromium executable for screenshot-based checks
# BROWSER_EXECUTABLE_PATH=/usr/bin/chromium-browser

NODE_ENV=development
